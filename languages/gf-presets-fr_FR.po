#. Plugin Name of the plugin
msgid "GF Presets"
msgstr "GF Presets"

#. Description of the plugin
msgid ""
"Global preset library for Gravity Forms fields, notifications, and confirmations. Save "
"once, apply anywhere — as a one-time copy or a synced live link."
msgstr ""
"Bibliothèque globale de préréglages pour les champs, notifications et confirmations Gravity "
"Forms. Enregistrez une fois, appliquez partout — en copie unique ou en lien synchronisé."

#: gf-presets.php
msgid "More information about GF Presets"
msgstr "Plus d'informations sur GF Presets"

#: gf-presets.php
msgid "View details"
msgstr "Voir les détails"

#: gf-presets.php
msgid "🐛 Report a Bug"
msgstr "🐛 Signaler un bug"

#: gf-presets.php
msgid "🐛 Report a Bug (install Bug Reporter)"
msgstr "🐛 Signaler un bug (installer Bug Reporter)"

#: class-gf-presets.php
msgid "Field Preset"
msgstr "Préréglage de champ"

#: class-gf-presets.php
msgid "Preset Library"
msgstr "Bibliothèque de préréglages"

#: class-gf-presets.php
msgid ""
"This preset is linked to %d forms. Deleting it will break all links and leave those forms "
"with their current settings (unaffected, but no longer synced). Continue?"
msgstr ""
"Ce préréglage est lié à %d formulaires. Le supprimer cassera tous les liens et laissera ces "
"formulaires avec leurs paramètres actuels (non affectés, mais plus synchronisés). "
"Continuer ?"

#: class-gf-presets.php
msgid "This object will keep its current settings but won't receive future updates. Continue?"
msgstr ""
"Cet objet conservera ses paramètres actuels mais ne recevra plus les mises à jour. "
"Continuer ?"

#: class-gf-presets.php
msgid "Preset saved. Synced to %d forms."
msgstr "Préréglage enregistré. Synchronisé sur %d formulaires."

#: class-gf-presets.php
msgid "Preset saved. Synced to %d forms. %d conflicts. %d errors."
msgstr "Préréglage enregistré. Synchronisé sur %d formulaires. %d conflits. %d erreurs."

#: class-gf-presets.php
msgid "Preset deleted."
msgstr "Préréglage supprimé."

#: class-gf-presets.php
msgid "An error occurred. Please try again."
msgstr "Une erreur est survenue. Veuillez réessayer."

#: class-gf-presets.php
msgid "Active"
msgstr "Actif"

#: class-gf-presets.php
msgid "Inactive"
msgstr "Inactif"

#: class-gf-presets.php
msgid "Preset saved."
msgstr "Préréglage enregistré."

#: class-gf-presets.php
msgid "Preset applied."
msgstr "Préréglage appliqué."

#: class-gf-presets.php
msgid "CL remapped: %s. Dropped: %s."
msgstr "LC remappée : %s. Supprimée : %s."

#: class-gf-presets.php admin/views/modal-apply.php
msgid ""
"Conditional logic will be remapped by matching field labels. Rules referencing fields not "
"found in this form will be dropped."
msgstr ""
"La logique conditionnelle sera remappée en faisant correspondre les libellés des champs. "
"Les règles référençant des champs absents de ce formulaire seront supprimées."

#: class-gf-presets.php
msgid ""
"This field will keep its current settings but won't receive future updates from the preset. "
"Continue?"
msgstr ""
"Ce champ conservera ses paramètres actuels mais ne recevra plus les mises à jour du "
"préréglage. Continuer ?"

#: class-gf-presets.php
msgid "Live link removed."
msgstr "Lien synchronisé supprimé."

#: class-gf-presets.php
msgid ""
"This field is live-linked. Saving this form will push your changes to all other forms using "
"this preset."
msgstr ""
"Ce champ est lié en temps réel. Enregistrer ce formulaire propagera vos modifications à "
"tous les autres formulaires utilisant ce préréglage."

#: class-gf-presets.php
msgid "This field has not been saved yet. Please save the form first, then apply the preset."
msgstr ""
"Ce champ n'a pas encore été enregistré. Veuillez d'abord enregistrer le formulaire, puis "
"appliquer le préréglage."

#: class-gf-presets.php
msgid "The form has no saved fields. Please save the form first, then apply the preset."
msgstr ""
"Le formulaire n'a aucun champ enregistré. Veuillez d'abord enregistrer le formulaire, puis "
"appliquer le préréglage."

#: class-gf-presets.php
msgid "Linked to preset: \"%s\""
msgstr "Lié au préréglage : « %s »"

#: class-gf-presets.php
msgid "This preset contains field-specific merge tags that may not exist in this form: %s"
msgstr ""
"Ce préréglage contient des balises de fusion spécifiques à des champs qui peuvent ne pas "
"exister dans ce formulaire : %s"

#. translators: %1$s: preset field type, %2$s: target field type
#: class-gf-presets.php
msgid "Type mismatch: this preset is for \"%1$s\" fields but the target field is \"%2$s\"."
msgstr ""
"Incompatibilité de type : ce préréglage est pour les champs « %1$s » mais le champ cible "
"est « %2$s »."

#: admin/class-preset-admin.php
msgid "All"
msgstr "Tous"

#: admin/class-preset-admin.php
msgid "Fields"
msgstr "Champs"

#: admin/class-preset-admin.php
msgid "Notifications"
msgstr "Notifications"

#: admin/class-preset-admin.php
msgid "Confirmations"
msgstr "Confirmations"

#: admin/class-preset-admin.php
msgid "New Preset"
msgstr "Nouveau préréglage"

#: admin/class-preset-admin.php
msgid "Search presets…"
msgstr "Rechercher des préréglages…"

#: admin/class-preset-admin.php
msgid "Loading presets…"
msgstr "Chargement des préréglages…"

#: admin/class-preset-admin.php
msgid "No presets yet"
msgstr "Aucun préréglage"

#: admin/class-preset-admin.php
msgid ""
"Save a field, notification, or confirmation as a preset to start building your library."
msgstr ""
"Enregistrez un champ, une notification ou une confirmation comme préréglage pour commencer "
"à constituer votre bibliothèque."

#: admin/views/modal-apply.php
msgid "Apply Preset:"
msgstr "Appliquer le préréglage :"

#: admin/views/modal-apply.php
msgid "Close"
msgstr "Fermer"

#: admin/views/modal-apply.php
msgid "How do you want to apply this preset?"
msgstr "Comment souhaitez-vous appliquer ce préréglage ?"

#: admin/views/modal-apply.php
msgid "Copy"
msgstr "Copie"

#: admin/views/modal-apply.php
msgid "Independent copy. No future sync."
msgstr "Copie indépendante. Pas de synchronisation future."

#: admin/views/modal-apply.php
msgid "Live Link"
msgstr "Lien synchronisé"

#: admin/views/modal-apply.php
msgid "Stays synced with the preset."
msgstr "Reste synchronisé avec le préréglage."

#: admin/views/modal-apply.php
msgid "Changes to the preset will overwrite this object in all linked forms automatically."
msgstr ""
"Les modifications du préréglage écraseront automatiquement cet objet dans tous les "
"formulaires liés."

#: admin/views/modal-apply.php
msgid "Merge Tag Warning"
msgstr "Avertissement balises de fusion"

#: admin/views/modal-apply.php
msgid "This preset contains field-specific merge tags:"
msgstr "Ce préréglage contient des balises de fusion spécifiques à des champs :"

#: admin/views/modal-apply.php
msgid "These field IDs may not exist in this form. Review and update them after applying."
msgstr ""
"Ces identifiants de champs peuvent ne pas exister dans ce formulaire. Vérifiez-les et "
"mettez-les à jour après application."

#: admin/views/modal-apply.php
msgid "Cancel"
msgstr "Annuler"

#: admin/views/modal-apply.php
msgid "Apply Preset"
msgstr "Appliquer le préréglage"

#: admin/views/modal-save.php
msgid "Save as Preset"
msgstr "Enregistrer comme préréglage"

#: admin/views/modal-save.php
msgid "Name"
msgstr "Nom"

#: admin/views/modal-save.php
msgid "Description (optional)"
msgstr "Description (facultatif)"

#: admin/views/modal-save.php
msgid "Conditional logic rules will be saved with label mapping for portability across forms."
msgstr ""
"Les règles de logique conditionnelle seront enregistrées avec un mappage par libellé pour "
"la portabilité entre formulaires."

#: admin/views/modal-save.php
msgid "Save Preset"
msgstr "Enregistrer le préréglage"

#: includes/class-preset-field.php
msgid "CL remapped: \"%1$s\" → field #%2$s."
msgstr "LC remappée : « %1$s » → champ #%2$s."

#: includes/class-preset-field.php
msgid "CL dropped: \"%s\" (no match in this form)."
msgstr "LC supprimée : « %s » (aucune correspondance dans ce formulaire)."

#: includes/class-preset-notification.php
